#!/bin/bash

NOTIFY_ID_FILE="${XDG_RUNTIME_DIR:-/tmp}/myshell-volume-notification.id"

get_current_volume() {
  wpctl get-volume @DEFAULT_AUDIO_SINK@ | awk '{print int($2 * 100)}'
}

get_mute_status() {
  wpctl get-volume @DEFAULT_AUDIO_SINK@ | grep -q MUTED && echo "Muted" || echo "Unmuted"
}

send_volume_notification() {
  local icon="$1"
  local summary="$2"
  shift 2

  local replace_args=()
  local notification_id=""

  if [ -f "$NOTIFY_ID_FILE" ]; then
    notification_id=$(cat "$NOTIFY_ID_FILE" 2>/dev/null)
    if [ -n "$notification_id" ]; then
      replace_args=(-r "$notification_id")
    fi
  fi

  notification_id=$(notify-send -p -a "changeVolume" -e -t 1400 "${replace_args[@]}" -i "$icon" "$summary" "$@")
  if [ -n "$notification_id" ]; then
    printf '%s\n' "$notification_id" > "$NOTIFY_ID_FILE"
  fi
}

case "$1" in
  up)
    if [ "$(get_current_volume)" -lt 100 ]; then
      wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+
    fi
    current_volume=$(get_current_volume)
    mute_status=$(get_mute_status)
    if [ "$mute_status" == "Unmuted" ]; then
      send_volume_notification audio-volume-high "Volume: ${current_volume}%" -h int:value:"$current_volume"
    fi
    ;;
  down)
    wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-
    current_volume=$(get_current_volume)
    mute_status=$(get_mute_status)
    if [ "$mute_status" == "Unmuted" ]; then
      send_volume_notification audio-volume-high "Volume: ${current_volume}%" -h int:value:"$current_volume"
    fi
    ;;
  mute)
    wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle
    mute_status=$(get_mute_status)
    if [ "$mute_status" == "Muted" ]; then
      send_volume_notification audio-volume-muted "Volume: Muted"
    else
      current_volume=$(get_current_volume)
      send_volume_notification audio-volume-high "Volume: Unmuted" -h int:value:"$current_volume"
    fi
    ;;
  *)
    echo "Usage: $0 {up|down|mute}"
    exit 1
    ;;
esac
